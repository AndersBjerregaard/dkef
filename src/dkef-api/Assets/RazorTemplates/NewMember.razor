@namespace Dkef.Assets.RazorTemplates
@using Dkef.Assets.RazorTemplates.Shared
@* NewMember.razor - Email template for new member registration notification *@

<!doctype html>
<html lang="da">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <title>Nyt medlem — DKEF</title>
        <EmailBaseStyles />
    </head>

    <body>
        <div class="email-outer">
            <div class="email-card">
                <!-- Header -->
                <div class="email-header">
                    <p class="org-label">Elektroteknisk Forening</p>
                    <h1>Nyt medlem registreret</h1>
                    <p class="subtitle">
                        Der er blevet registreret et nyt medlem
                    </p>
                </div>

                <!-- Amber accent bar -->
                <div class="accent-bar"></div>

                <!-- Body -->
                <div class="email-body">
                    <p class="intro-text">
                        Hej,<br /><br />
                        Et nyt medlem har registreret sig på
                        <strong style="color: #f1f5f9">dkef.dk</strong>.
                        Oplysninger på det nye medlem fremgår nedenfor.
                    </p>

                    <!-- Personal Information Section -->
                    <div class="info-grid">
                        <!-- Name (required) -->
                        <div class="info-row">
                            <div class="info-icon">👤</div>
                            <div class="info-content">
                                <p class="info-label">Navn</p>
                                <p class="info-value">@Name</p>
                            </div>
                        </div>

                        <!-- Email (required) -->
                        <div class="info-row">
                            <div class="info-icon">✉️</div>
                            <div class="info-content">
                                <p class="info-label">E-mailadresse</p>
                                <p class="info-value">@Email</p>
                            </div>
                        </div>

                        <!-- Phone (optional) -->
                        @if (!string.IsNullOrWhiteSpace(Phone))
                        {
                            <div class="info-row">
                                <div class="info-icon">📞</div>
                                <div class="info-content">
                                    <p class="info-label">Telefonnummer</p>
                                    <p class="info-value">@Phone</p>
                                </div>
                            </div>
                        }

                        <!-- Title (optional) -->
                        @if (!string.IsNullOrWhiteSpace(Title))
                        {
                            <div class="info-row">
                                <div class="info-icon">💼</div>
                                <div class="info-content">
                                    <p class="info-label">Titel</p>
                                    <p class="info-value">@Title</p>
                                </div>
                            </div>
                        }

                        <!-- Employment Status (optional) -->
                        @if (!string.IsNullOrWhiteSpace(EmploymentStatus))
                        {
                            <div class="info-row">
                                <div class="info-icon">👨‍💼</div>
                                <div class="info-content">
                                    <p class="info-label">Ansættelsesstatus</p>
                                    <p class="info-value">@EmploymentStatus</p>
                                </div>
                            </div>
                        }

                        <!-- Primary Section (required) -->
                        @if (PrimarySection != null)
                        {
                            <div class="info-row">
                                <div class="info-icon">⭐</div>
                                <div class="info-content">
                                    <p class="info-label">Primær sektion</p>
                                    <p class="info-value">@PrimarySection</p>
                                </div>
                            </div>
                        }

                        <!-- Secondary Section (optional) -->
                        @if (SecondarySection.HasValue)
                        {
                            <div class="info-row">
                                <div class="info-icon">✓</div>
                                <div class="info-content">
                                    <p class="info-label">Sekundær sektion</p>
                                    <p class="info-value">@SecondarySection</p>
                                </div>
                            </div>
                        }

                        <!-- Magazine Delivery (required) -->
                        <div class="info-row">
                            <div class="info-icon">📰</div>
                            <div class="info-content">
                                <p class="info-label">Magasinlevering</p>
                                <p class="info-value">@MagazineDelivery</p>
                            </div>
                        </div>

                        <!-- Subscription (required) -->
                        <div class="info-row">
                            <div class="info-icon">🔔</div>
                            <div class="info-content">
                                <p class="info-label">Abonnement</p>
                                <p class="info-value">@Subscription</p>
                            </div>
                        </div>
                    </div>

                    <!-- Address Section -->
                    @if (!string.IsNullOrWhiteSpace(Address) ||
                         !string.IsNullOrWhiteSpace(ZIP) ||
                         !string.IsNullOrWhiteSpace(City))
                    {
                        <div class="divider"></div>
                        <p class="section-title">📍 Adresseoplysninger</p>
                        <div class="info-grid">
                            @if (!string.IsNullOrWhiteSpace(Address))
                            {
                                <div class="info-row">
                                    <div class="info-icon">🏠</div>
                                    <div class="info-content">
                                        <p class="info-label">Adresse</p>
                                        <p class="info-value">@Address</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(ZIP))
                            {
                                <div class="info-row">
                                    <div class="info-icon">📮</div>
                                    <div class="info-content">
                                        <p class="info-label">Postnummer</p>
                                        <p class="info-value">@ZIP</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(City))
                            {
                                <div class="info-row">
                                    <div class="info-icon">🏙️</div>
                                    <div class="info-content">
                                        <p class="info-label">By</p>
                                        <p class="info-value">@City</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- Company Information Section -->
                    @if (!string.IsNullOrWhiteSpace(CompanyName) ||
                         !string.IsNullOrWhiteSpace(CompanyAddress) ||
                         !string.IsNullOrWhiteSpace(CompanyZIP) ||
                         !string.IsNullOrWhiteSpace(CompanyCity) ||
                         !string.IsNullOrWhiteSpace(CompanyPhone) ||
                         !string.IsNullOrWhiteSpace(CVRNumber) ||
                         !string.IsNullOrWhiteSpace(EANNumber))
                    {
                        <div class="divider"></div>
                        <p class="section-title">🏢 Virksomhedsoplysninger</p>
                        <div class="info-grid">
                            @if (!string.IsNullOrWhiteSpace(CompanyName))
                            {
                                <div class="info-row">
                                    <div class="info-icon">🏭</div>
                                    <div class="info-content">
                                        <p class="info-label">Virksomhedsnavn</p>
                                        <p class="info-value">@CompanyName</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(CompanyAddress))
                            {
                                <div class="info-row">
                                    <div class="info-icon">🏠</div>
                                    <div class="info-content">
                                        <p class="info-label">Virksomhedsadresse</p>
                                        <p class="info-value">@CompanyAddress</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(CompanyZIP))
                            {
                                <div class="info-row">
                                    <div class="info-icon">📮</div>
                                    <div class="info-content">
                                        <p class="info-label">Postnummer (virksomhed)</p>
                                        <p class="info-value">@CompanyZIP</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(CompanyCity))
                            {
                                <div class="info-row">
                                    <div class="info-icon">🏙️</div>
                                    <div class="info-content">
                                        <p class="info-label">By (virksomhed)</p>
                                        <p class="info-value">@CompanyCity</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(CompanyPhone))
                            {
                                <div class="info-row">
                                    <div class="info-icon">📞</div>
                                    <div class="info-content">
                                        <p class="info-label">Telefonnummer (virksomhed)</p>
                                        <p class="info-value">@CompanyPhone</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(CVRNumber))
                            {
                                <div class="info-row">
                                    <div class="info-icon">🔢</div>
                                    <div class="info-content">
                                        <p class="info-label">CVR-nummer</p>
                                        <p class="info-value">@CVRNumber</p>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(EANNumber))
                            {
                                <div class="info-row">
                                    <div class="info-icon">🔢</div>
                                    <div class="info-content">
                                        <p class="info-label">EAN-nummer</p>
                                        <p class="info-value">@EANNumber</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div class="divider"></div>

                    <!-- Metadata -->
                    <div class="meta-strip">
                        <strong>Tidspunkt:</strong> @ReceivedAt<br />
                        <strong>Kilde:</strong> dkef.dk
                    </div>
                </div>

                <!-- Footer -->
                <div class="email-footer">
                    <p class="footer-org">DKEF</p>
                    <p class="footer-address">
                        Elleholmvej 28C, 5250 Odense SV<br />
                        <a href="mailto:info@dkef.dk">info@dkef.dk</a>
                        &nbsp;·&nbsp;
                        <a href="tel:+4542577069">+45 42 57 70 69</a>
                    </p>
                    <p class="footer-note">
                        Denne e-mail er automatisk genereret af systemet på
                        dkef.dk og er kun beregnet til sekretærens brug.
                    </p>
                </div>
            </div>
        </div>
    </body>
</html>

@code {
    /// <summary>
    /// Full name of the new member
    /// </summary>
    [Parameter]
    public string Name { get; set; } = string.Empty;

    /// <summary>
    /// Email address of the new member
    /// </summary>
    [Parameter]
    public string Email { get; set; } = string.Empty;

    /// <summary>
    /// Phone number of the new member
    /// </summary>
    [Parameter]
    public string Phone { get; set; } = string.Empty;

    /// <summary>
    /// Job title of the new member
    /// </summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;

    /// <summary>
    /// Employment status of the new member
    /// </summary>
    [Parameter]
    public string EmploymentStatus { get; set; } = string.Empty;

    /// <summary>
    /// Street address of the new member
    /// </summary>
    [Parameter]
    public string Address { get; set; } = string.Empty;

    /// <summary>
    /// Postal code of the new member
    /// </summary>
    [Parameter]
    public string ZIP { get; set; } = string.Empty;

    /// <summary>
    /// City of the new member
    /// </summary>
    [Parameter]
    public string City { get; set; } = string.Empty;

    /// <summary>
    /// Primary section of the new member
    /// </summary>
    [Parameter]
    public Dkef.Domain.Section? PrimarySection { get; set; }

    /// <summary>
    /// Secondary section of the new member (optional)
    /// </summary>
    [Parameter]
    public Dkef.Domain.Section? SecondarySection { get; set; }

    /// <summary>
    /// Magazine delivery preference
    /// </summary>
    [Parameter]
    public string MagazineDelivery { get; set; } = string.Empty;

    /// <summary>
    /// Subscription preference
    /// </summary>
    [Parameter]
    public string Subscription { get; set; } = string.Empty;

    /// <summary>
    /// Company name (if applicable)
    /// </summary>
    [Parameter]
    public string CompanyName { get; set; } = string.Empty;

    /// <summary>
    /// Company street address (if applicable)
    /// </summary>
    [Parameter]
    public string CompanyAddress { get; set; } = string.Empty;

    /// <summary>
    /// Company postal code (if applicable)
    /// </summary>
    [Parameter]
    public string CompanyZIP { get; set; } = string.Empty;

    /// <summary>
    /// Company city (if applicable)
    /// </summary>
    [Parameter]
    public string CompanyCity { get; set; } = string.Empty;

    /// <summary>
    /// Company phone number (if applicable)
    /// </summary>
    [Parameter]
    public string CompanyPhone { get; set; } = string.Empty;

    /// <summary>
    /// CVR number of the company (if applicable)
    /// </summary>
    [Parameter]
    public string CVRNumber { get; set; } = string.Empty;

    /// <summary>
    /// EAN number of the company (if applicable)
    /// </summary>
    [Parameter]
    public string EANNumber { get; set; } = string.Empty;

    /// <summary>
    /// Timestamp when the registration was received
    /// </summary>
    [Parameter]
    public string ReceivedAt { get; set; } = string.Empty;
}
