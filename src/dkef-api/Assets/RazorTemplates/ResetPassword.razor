@namespace Dkef.Assets.RazorTemplates
@using Dkef.Assets.RazorTemplates.Shared

<!doctype html>
<html lang="da">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <title>Glemt Adgangskode</title>
        <EmailBaseStyles />
    </head>

    <body>
        <div class="email-outer">
            <div class="email-card">
                <!-- Header -->
                <div class="email-header">
                    <p class="org-label">Elektroteknisk Forening</p>
                    <h1>Glemt Adganskode</h1>
                </div>

                <!-- Amber accent bar -->
                <div class="accent-bar"></div>

                <!-- Body -->
                <div class="email-body">
                    <p class="intro-text">
                        Hej, @Name<br /><br />
                        Vi har modtaget en anmodning om at nulstille din
                        adgangskode for din
                        <strong>dkef.dk</strong> medlemskonto. Klik på knappen
                        forneden for at vælge en ny:
                    </p>

                    <!-- Confirm CTA -->
                    <div class="cta-section">
                        <a class="cta-button" href="@ChangeLink">
                            Nulstil Adgangskode
                        </a>
                    </div>

                    <!-- Security Concerns -->
                    <p class="intro-text">
                        <strong>OBS:</strong> Dette link vil kun være gyldigt i
                        24 timer og kan kun benyttes én gang.<br /><br />
                        Hvis du ikke har anmodet om at ændrer din adgangskode,
                        kan du trygt ignorere denne e-mail. Din nuværende
                        adgangskode forbliver aktiv, og der vil ikke blive
                        foretaget ændringer på din konto.
                    </p>

                    <div class="divider"></div>

                    <!-- Metadata -->
                    <div class="meta-strip">
                        <strong>Tidspunkt:</strong> @ReceivedAt<br />
                        <strong>Kilde:</strong> dkef.dk
                    </div>
                </div>

                <!-- Footer -->
                <div class="email-footer">
                    <p class="footer-org">DKEF</p>
                    <p class="footer-address">
                        Elleholmvej 28C, 5250 Odense SV<br />
                        <a href="mailto:info@dkef.dk">info@dkef.dk</a>
                        &nbsp;·&nbsp;
                        <a href="tel:+4542577069">+45 42 57 70 69</a>
                    </p>
                    <p class="footer-note">
                        Denne e-mail er automatisk genereret af systemet på
                        dkef.dk og kan ikke besvares.
                    </p>
                </div>
            </div>
        </div>
    </body>
</html>

@code {
    [Parameter] public string Name { get; set; } = string.Empty;
    [Parameter] public string ChangeLink { get; set; } = string.Empty;
    [Parameter] public string ReceivedAt { get; set; } = string.Empty;
}
