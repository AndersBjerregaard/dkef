# Ansible Vault secrets file — DO NOT commit the real secrets.yaml to git.
#
# Create the real vault file with:
#   ansible-vault create vars/secrets.yaml
#
# To edit later:
#   ansible-vault edit vars/secrets.yaml
#
# Run the playbook with vault decryption:
#   ansible-playbook -i inventory.ini site.yaml -K --ask-vault-pass
#
# Required variables:

# Postgres
postgres_user: "changeme"
postgres_password: "changeme"
postgres_db: "changeme"

# MinIO
minio_access_key: "changeme"
minio_secret_key: "changeme"

# API
# Full Npgsql connection string — host must match the k8s Service name (postgres)
api_postgres_connection_string: "Host=postgres;Port=5432;Username=changeme;Password=changeme;Database=changeme"
# MinIO endpoint as <host>:<port> — host must match the k8s Service name (minio)
api_minio_connection_string: "minio:9000"
# JWT signing key — minimum 32 characters
jwt_key: "changeme-minimum-32-characters-long-secret-key"
